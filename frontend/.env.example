# Student Intelligence Layer frontend environment
# Copy this file to frontend/.env and replace placeholder values.
#
# Important current implementation note:
# - Landing imports Supabase client at startup.
# - If these Supabase vars are missing, the frontend will throw on boot.

# Backend API base URL
VITE_API_BASE=http://localhost:4000

# Supabase waitlist configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace_with_supabase_anon_key
