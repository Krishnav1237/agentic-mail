# Student Intelligence Layer backend environment
# Copy this file to backend/.env and replace placeholder values.
#
# Important current implementation note:
# - Microsoft OAuth env vars are required at backend startup.
# - If you are testing Gmail first, you still need placeholder Microsoft values.

# Runtime
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# Core infrastructure
DATABASE_URL=postgres://postgres:postgres@localhost:5432/student_intel
REDIS_URL=redis://localhost:6379

# Application auth
AUTH_JWT_SECRET=replace_with_a_long_random_secret
AUTH_JWT_ISSUER=student-intel
AUTH_JWT_AUDIENCE=student-intel-web
AUTH_COOKIE_NAME=sil_auth

# Token encryption
# Must be a stable base64-encoded 32-byte key in real environments.
TOKEN_ENC_KEY=replace_with_base64_32_byte_key

# Microsoft OAuth (currently required at startup)
MS_CLIENT_ID=replace_with_azure_app_client_id
MS_CLIENT_SECRET=replace_with_azure_app_client_secret
MS_TENANT_ID=common
MS_REDIRECT_URI=http://localhost:4000/auth/microsoft/callback
MS_SCOPES=offline_access User.Read Mail.Read Mail.ReadWrite Calendars.ReadWrite
# Optional, but needed for Graph webhook freshness.
MS_WEBHOOK_NOTIFICATION_URL=

# Google OAuth
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback
GOOGLE_SCOPES=openid email profile https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/gmail.modify https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/calendar

# AI provider selection
# Valid current providers in code: openrouter, groq, gemini
AI_PROVIDER=openrouter
AI_MODEL=google/gemini-1.5-pro-latest
OPENROUTER_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# AI runtime controls
AI_TIMEOUT_MS=20000
AI_MAX_RETRIES=2
AGENT_LOOP_MAX_MS=8000

# Sync and cache behavior
SYNC_BATCH_SIZE=50
CACHE_TTL_SECONDS=60
