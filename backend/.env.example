NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173
# Production example:
# FRONTEND_URL=https://your-app.vercel.app,https://your-app-*.vercel.app
SECURITY_CONTACT=
SECURITY_POLICY_URL=

DATABASE_URL=postgres://postgres:postgres@localhost:5433/inbox_intel
REDIS_URL=redis://localhost:6379
QUEUE_REDIS_URL=
CACHE_REDIS_URL=

AUTH_JWT_SECRET=change_me
AUTH_JWT_ISSUER=inbox-intel
AUTH_JWT_AUDIENCE=inbox-intel-web
AUTH_COOKIE_NAME=iil_auth
AUTH_CSRF_COOKIE_NAME=iil_csrf
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=
TOKEN_ENC_KEY=base64_32_bytes

# Microsoft OAuth
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common
MS_REDIRECT_URI=http://localhost:4000/auth/microsoft/callback
MS_SCOPES=offline_access User.Read Mail.Read Mail.ReadWrite Calendars.ReadWrite
MS_WEBHOOK_NOTIFICATION_URL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback
GOOGLE_SCOPES=openid email profile https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/gmail.modify https://www.googleapis.com/auth/gmail.compose https://www.googleapis.com/auth/calendar.events

# Resend
# Replace re_xxxxxxxxx with your real Resend API key.
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# AI
AI_PROVIDER=openrouter
AI_MODEL=google/gemini-1.5-pro-latest
OPENROUTER_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
AI_TIMEOUT_MS=20000
AI_MAX_RETRIES=2
AGENT_LOOP_MAX_MS=8000

SYNC_BATCH_SIZE=50
CACHE_TTL_SECONDS=60
DATA_RETENTION_DEFAULT_DAYS=180
DATA_RETENTION_MIN_DAYS=7
DATA_RETENTION_MAX_DAYS=365
